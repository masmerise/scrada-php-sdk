{
    "name": "masmerise/scrada-php-sdk",
    "description": "An unofficial PHP SDK for accessing Scrada's API.",
    "license": "MIT",
    "keywords": [
        "scrada",
        "api",
        "sdk"
    ],
    "authors": [
        {
            "name": "Muhammed Sari",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/masmerise/scrada-php-sdk",
    "require": {
        "php": "~8.5",
        "psr/simple-cache": "^3.0",
        "saloonphp/rate-limit-plugin": "^2.0",
        "saloonphp/saloon": "^4.0",
        "webmozart/assert": "^2.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29.0",
        "phpstan/phpstan": "^2.1.44",
        "phpunit/phpunit": "^13.0.5",
        "vlucas/phpdotenv": "^5.6.3"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Scrada\\": "src"
        },
        "files": [
            "src/Core/Utility/transform.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Scrada\\Tests\\": "tests"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "format": "vendor/bin/pint",
        "stan": "vendor/bin/phpstan analyse --memory-limit=2G",
        "test": "vendor/bin/phpunit",
        "verify": ["@stan", "@test"]
    }
}
